# eleven-7 backend environment (copy to .env)
NODE_ENV=development
PORT=4000

# --- MySQL -------------------------------------------------------------------
DB_HOST=localhost
DB_PORT=3306
DB_USER=eleven7
DB_PASSWORD=eleven7pass
DB_NAME=eleven7
DB_CONNECTION_LIMIT=10

# --- AWS (LocalStack by default; no real account needed) ----------------------
# Point the SDK at LocalStack. To use real AWS, clear AWS_ENDPOINT_URL and set real creds.
AWS_REGION=ap-southeast-1
AWS_ENDPOINT_URL=http://localhost:4566
AWS_ACCESS_KEY_ID=test
AWS_SECRET_ACCESS_KEY=test

# Resource names/ARNs (created by localstack/init-aws.sh)
SNS_ORDER_TOPIC_ARN=arn:aws:sns:ap-southeast-1:000000000000:eleven7-order-events
SQS_ORDER_QUEUE_URL=http://localhost:4566/000000000000/eleven7-order-processing
SQS_DISPATCH_QUEUE_URL=http://localhost:4566/000000000000/eleven7-delivery-dispatch

# When true, AWS calls are stubbed in-process (no LocalStack required) and recorded
# to the notifications table only. Great for offline dev/tests.
AWS_FAKE_MODE=false
